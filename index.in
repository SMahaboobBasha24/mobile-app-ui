<!DOCTYPE html>
<html>
<head>
<title>Mobile App UI</title>

<style>

body{
font-family:Arial;
background:#0f172a;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.app{
width:320px;
height:550px;
background:#1e293b;
border-radius:15px;
overflow:hidden;
color:white;
display:flex;
flex-direction:column;
}

.header{
display:flex;
justify-content:space-between;
padding:10px;
background:#334155;
}

.stories{
display:flex;
gap:10px;
padding:10px;
overflow-x:auto;
}

.story{
width:50px;
height:50px;
border-radius:50%;
background:#22c55e;
display:flex;
align-items:center;
justify-content:center;
font-size:12px;
}

.post{
padding:10px;
}

.post img{
width:100%;
border-radius:8px;
}

.actions{
margin-top:5px;
}

.caption{
margin-top:5px;
font-size:14px;
}

</style>

</head>

<body>

<div class="app">

<div class="header">
<span>📷 InstaClone</span>
<span>❤️ ✉️</span>
</div>

<div class="stories">
<div class="story">You</div>
<div class="story">A</div>
<div class="story">B</div>
<div class="story">C</div>
<div class="story">D</div>
</div>

<div class="post">
<img src="https://picsum.photos/300/200">
<div class="actions">❤️ 💬 🔗</div>
<div class="caption">Liked by 120 people</div>
</div>

</div>

</body>
</html>
